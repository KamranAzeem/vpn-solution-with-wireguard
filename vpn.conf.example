# WireGuard VPN — Configuration
# Edit these values before running initial-setup.sh
# This file stays in the repo (outside /etc/wireguard/)
# Copy this example file to vpn.conf and edit:
#   cp vpn.conf.example vpn.conf

# Target directory for WireGuard runtime files
WG_DIR="/etc/wireguard"

# VPN subnet
WG_SUBNET="192.168.111.0/24"
WG_SERVER_IP="192.168.111.1"

# Server network interface (run: ip route show default)
WG_INTERFACE="ens3"

# Public endpoint (hostname or IP)
WG_ENDPOINT="vpn.do.wbitt.com"
WG_PORT=51820

# DNS pushed to clients
WG_DNS="1.1.1.1"

# Email sender for automated config delivery
FROM_EMAIL="vpn-admin@example.com"

# Encrypt config before emailing (true=GPG encrypt, false=plaintext attachment)
ENCRYPT_CONFIG=true

# Target sensitive service (fill these when known)
# Option A — static IP range:
# TARGET_SERVICE_IPS="203.0.113.0/24"
# Option B — CDN domain (mutually exclusive with Option A):
# TARGET_SERVICE_DOMAIN="sensitive-service.example.com"

# Client AllowedIPs — set to TARGET_SERVICE_IPS for split tunnel, or 0.0.0.0/0 for full tunnel
ALLOWED_IPS="0.0.0.0/0"
